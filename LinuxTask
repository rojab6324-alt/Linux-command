6.Task: Parse /var/log/syslog for errors and send an email.
#!/bin/bash

grep -i "error" /var/log/syslog > error_report.txt

if [ -s error_report.txt ]; then
    mail -s "Syslog Errors Report" you@example.com < error_report.txt
fi

