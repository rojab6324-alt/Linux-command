2. Task: Warn if disk usage goes above a threshold.
#!/bin/bash

THRESHOLD=80

USAGE=$(df / | grep / | awk '{ print $5 }' | sed 's/%//g')

if [ "$USAGE" -gt "$THRESHOLD" ]; then
    echo "Warning: Disk usage is above $THRESHOLD%."
else
    echo "Disk usage is under control: $USAGE%."
fi
