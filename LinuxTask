3. Task: Add a prefix or suffix to all .txt files in a directory.
#!/bin/bash

PREFIX="archived_"

for file in *.txt; do
    mv "$file" "${PREFIX}${file}"
done

echo "Files renamed with prefix '$PREFIX'"

